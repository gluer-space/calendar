{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "calendar-scheduler",
  "homepage": "https://github.com/gluer-space/calendar",
  "items": [
    {
      "name": "calendar-scheduler",
      "type": "registry:block",
      "title": "Calendar Scheduler",
