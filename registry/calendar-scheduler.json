    },
    {
      "path": "registry/calendar/month-view.tsx",
      "type": "registry:component"
    },
    {
      "path": "registry/calendar/week-view.tsx",
      "type": "registry:component"
    },
    {
      "path": "registry/calendar/day-view.tsx",
      "type": "registry:component"
    },
    {
      "path": "registry/calendar/agenda-view.tsx",
      "type": "registry:component"
    },
    {
      "path": "registry/calendar/timezone-selector.tsx",
      "type": "registry:component"
    },
    {
      "path": "registry/calendar/view-switcher.tsx",
      "type": "registry:component"
    },
    {
      "path": "registry/calendar/slot-btn.tsx",
      "type": "registry:component"
    },
    {
      "path": "registry/calendar/tooltip.tsx",
      "type": "registry:component"
    },
    {
      "path": "registry/calendar/helpers.ts",
      "type": "registry:lib"
    },
    {
      "path": "registry/calendar/timezones.ts",
